# ── LLM Configuration ─────────────────────────────────────────────────────────
# Provider: ollama-cloud (default) | ollama (local) | openai | openrouter
LLM_PROVIDER=ollama-cloud

# Model — runs on Ollama Cloud GPUs, no local GPU needed
LLM_MODEL=qwen3-vl:32b-thinking
# VISION_MODEL=qwen3-vl:32b-thinking   # override vision model separately
# TEXT_MODEL=qwen3-vl:32b-thinking      # override text-only model separately

# Ollama Cloud API — get key at https://ollama.com/settings/keys
OLLAMA_API_KEY=
OLLAMA_CLOUD_HOST=https://ollama.com

# ── Alternative Providers (optional) ──────────────────────────────────────────
# Local Ollama (no API key needed, requires local Ollama install)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434

# OpenAI
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# OpenRouter
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=sk-or-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── App Configuration ─────────────────────────────────────────────────────────
# AUTH_SECRET=                    # Set to enable token auth (leave empty for open access)
# CORS_ORIGIN=http://localhost:5173
# STYLE_DB_PATH=data/styles.db   # Path for style fingerprint database
