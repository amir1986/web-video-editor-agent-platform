{
  "name": "web-video-editor-agent-platform",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/core"
  ],
  "scripts": {
    "dev": "concurrently -n api,bot,web -c blue,magenta,green \"npm run dev --workspace=apps/api\" \"npm run bot --workspace=apps/api\" \"npm run dev --workspace=apps/web\"",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:bot": "npm run bot --workspace=apps/api",
    "dev:web": "npm run dev --workspace=apps/web",
    "build": "npm run build --workspace=apps/web",
    "lint": "npm run lint --workspace=apps/web --if-present",
    "typecheck": "npm run typecheck --workspace=apps/web --if-present",
    "test": "npm run test --workspace=apps/api",
    "check-deps": "node scripts/check-deps.js",
    "check-deps:full": "node scripts/check-deps.js --audit",
    "test:e2e": "npx playwright test --config e2e/playwright.config.ts",
    "test:e2e:headed": "npx playwright test --config e2e/playwright.config.ts --headed",
    "preinstall": "node scripts/preinstall.js"
  },
  "dependencies": {
    "@telegram.ts/types": "^1.26.0",
    "telegram": "^2.26.22"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^9.2.1"
  },
  "overrides": {
    "discord.js": {
      "undici": "6.24.1"
    },
    "@discordjs/rest": {
      "undici": "6.24.1"
    },
    "@discordjs/ws": {
      "undici": "6.24.1"
    },
    "undici": "7.24.2",
    "file-type": "21.3.2"
  }
}
