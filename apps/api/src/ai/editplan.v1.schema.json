{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "title": "EditPlan",
  "description": "Multi-agent video editing plan. Produced by Cut → Structure → Continuity → Transition → Constraints → Quality Guard pipeline.",
  "additionalProperties": false,
  "required": ["render_constraints", "segments", "transitions", "notes", "quality_guard"],
  "properties": {
    "render_constraints": {
      "type": "object",
      "description": "Hard constraints the renderer must enforce. Quality Guard agent validates and corrects these.",
      "required": ["keep_resolution", "keep_aspect_ratio", "no_stretch", "target_width", "target_height"],
      "properties": {
        "keep_resolution": { "type": "boolean", "const": true },
        "keep_aspect_ratio": { "type": "boolean", "const": true },
        "no_stretch": { "type": "boolean", "const": true },
        "target_width": { "type": "integer", "minimum": 0, "description": "Original video width in pixels" },
        "target_height": { "type": "integer", "minimum": 0, "description": "Original video height in pixels" },
        "codec": { "type": "string", "description": "Video codec for re-encode (only when soft transitions require it)" },
        "crf": { "type": "integer", "minimum": 0, "maximum": 51, "description": "CRF quality value (lower = better, 18 = visually lossless)" },
        "preset": { "type": "string", "description": "Encoding preset (never ultrafast/superfast/veryfast)" },
        "pixel_format": { "type": "string", "description": "Pixel format (e.g. yuv420p)" },
        "sar": { "type": "string", "description": "Sample aspect ratio to enforce (e.g. 1:1 for square pixels)" },
        "fps": { "type": "number", "minimum": 0, "description": "Frame rate from source video" },
        "fps_mode": { "type": "string", "description": "Frame rate mode (cfr for constant, vfr for variable)" }
      }
    },
    "segments": {
      "type": "array",
      "description": "Ordered list of source segments to include in the highlight edit",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "src_in", "src_out"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^s\\d+$", "description": "Segment identifier (s1, s2, ...)" },
          "src_in": { "type": "number", "minimum": 0, "description": "Start time in source video (seconds)" },
          "src_out": { "type": "number", "minimum": 0, "description": "End time in source video (seconds)" }
        }
      }
    },
    "transitions": {
      "type": "array",
      "description": "Transitions between consecutive segments",
      "items": {
        "type": "object",
        "required": ["from", "to", "type"],
        "additionalProperties": false,
        "properties": {
          "from": { "type": "string", "description": "ID of the outgoing segment" },
          "to": { "type": "string", "description": "ID of the incoming segment" },
          "type": {
            "type": "string",
            "enum": ["hard_cut", "fade", "dissolve", "dip_to_black", "match_cut", "whip_cut", "jump_cut"],
            "description": "Transition type"
          }
        }
      }
    },
    "notes": {
      "type": "object",
      "description": "Validation notes from the Constraints Agent",
      "required": ["constraints_ok"],
      "properties": {
        "constraints_ok": { "type": "boolean", "description": "True if all constraints pass" },
        "issues": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of issues found (empty if constraints_ok is true)"
        }
      }
    },
    "quality_guard": {
      "type": "object",
      "description": "Quality Guard Agent output — audits and enforces technical output quality constraints",
      "required": ["constraints_ok", "checks", "required_fixes"],
      "properties": {
        "constraints_ok": {
          "type": "boolean",
          "description": "True if all quality checks pass (always true after corrections are applied)"
        },
        "checks": {
          "type": "object",
          "required": ["resolution_unchanged", "aspect_ratio_unchanged", "no_stretch", "no_unnecessary_reencode", "export_settings_not_platform_default"],
          "properties": {
            "resolution_unchanged": { "type": "boolean", "description": "Output resolution matches input exactly" },
            "aspect_ratio_unchanged": { "type": "boolean", "description": "Output aspect ratio matches input exactly" },
            "no_stretch": { "type": "boolean", "description": "No stretching to fit any canvas" },
            "no_unnecessary_reencode": { "type": "boolean", "description": "Stream copy used when all transitions are hard_cut" },
            "export_settings_not_platform_default": { "type": "boolean", "description": "Export settings derived from input, not platform defaults" },
            "fps_preserved": { "type": "boolean", "description": "Frame rate matches source (no stutter)" },
            "sar_dar_correct": { "type": "boolean", "description": "Pixel/display aspect ratio correctly handled" }
          }
        },
        "required_fixes": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of corrections applied (empty if all checks passed initially)"
        },
        "corrections_applied": {
          "type": "boolean",
          "description": "True if the Quality Guard had to correct render_constraints"
        }
      }
    }
  }
}
